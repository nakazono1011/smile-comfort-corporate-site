# automation/env.sh — 日次ハーネスの環境変数。
# このファイルを automation/env.sh にコピーして値を埋める (env.sh は .gitignore 済み・コミットしない)。
#   cp automation/env.sh.example automation/env.sh && $EDITOR automation/env.sh

# ---- Cloudflare R2 (記事画像アップロード) ----
# R2 バケット corporate-images に Object Read & Write 権限を持つ API トークン。
#   作成: Cloudflare Dashboard → R2 → Manage R2 API Tokens → Create API Token
#         (または My Profile → API Tokens で "Workers R2 Storage: Edit" 相当)
export CLOUDFLARE_API_TOKEN="__PUT_YOUR_R2_TOKEN_HERE__"
export CLOUDFLARE_ACCOUNT_ID="__PUT_YOUR_CLOUDFLARE_ACCOUNT_ID__"

# ---- X (Twitter) 検索 ----
# ~/.hermes/auth.json があれば不要。無い場合のみ xAI キーを設定。
# export XAI_API_KEY="xai-..."

# ---- 動作パラメータ ----
export ARTICLES_PER_DAY=3          # 1 日に生成する本数
export PUBLISH_MIN_SCORE=90        # この点以上のみ自動公開 (未満は holding へ)
export MAX_PER_PRODUCT_PER_DAY=2   # 1 日で同一製品を選ぶ上限 (多様性キャップ)
export PUBLISH_BRANCH=main         # 公開先ブランチ (Vercel 本番)
export CLAUDE_MODEL=opus           # ヘッドレス生成に使うモデル
export CLAUDE_TIMEOUT=14400        # claude ヘッドレスの上限秒 (4h。画像生成込みの保険。通常はもっと早い)

# ---- PATH (launchd は最小 PATH のため明示が必須) ----
# node / claude / wrangler / jq / caffeinate / osascript が解決できるように。
# install.sh がこのマシンで検出した実際のディレクトリを下に追記する。
export PATH="$HOME/.local/bin:$HOME/.hermes/node/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"
