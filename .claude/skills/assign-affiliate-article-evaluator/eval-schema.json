  "extras": {
    "feedback": "required",
    "passed": "required",
    "evaluator_skill": "required",
    "iteration": "required",
    "link_checks": "required"
  },
  "passing_rule": "(score / 110) * 100 >= 90",
  "ref": "ref-affiliate-article",
  "rubric": null,
  "notes": "満点は 110 (link_health 軸を含む)。passing_rule は正規化後 90 点以上。3 回ループで未達なら親 (run-affiliate-article) が判断 (打ち切り / 4 周目 / 人手介入)。link_health は HTTP HEAD で 2xx 以外を全て減点、致命 (>=2 件) なら threshold 割れで即不合格扱い。"
}
